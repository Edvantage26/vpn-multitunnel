{
  "version": 1,
  "settings": {
    "configDir": "./configs",
    "logLevel": "info",
    "autoConnect": [],
    "portRangeStart": 10800,
    "minimizeToTray": true,
    "startMinimized": false
  },
  "profiles": [
    {
      "id": "contabo-docker-abc12345",
      "name": "Contabo Docker Services",
      "configFile": "Edgar-Contabo-2.conf",
      "enabled": true,
      "healthCheck": {
        "enabled": true,
        "targetIP": "10.8.0.1",
        "intervalSeconds": 30
      },
      "dns": {
        "server": "172.23.0.53",
        "domains": [".contabo.internal"]
      }
    }
  ],
  "dnsProxy": {
    "enabled": true,
    "listenPort": 10053,
    "rules": [
      {
        "suffix": ".contabo.internal",
        "profileId": "contabo-docker-abc12345",
        "dnsServer": "172.23.0.53"
      },
      {
        "suffix": ".svi.local",
        "profileId": "svi-network-def67890",
        "dnsServer": "172.23.0.53"
      }
    ],
    "fallback": "system"
  }
}
